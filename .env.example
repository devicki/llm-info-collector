# Hugging Face (선택사항 - 없으면 anonymous rate limit 적용)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (선택사항 - 기본값: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Civitai (선택사항 - 없으면 공개 API만 사용)
CIVITAI_API_TOKEN=your_civitai_api_token_here

# ModelScope (선택사항 - 없으면 공개 API만 사용)
MODELSCOPE_API_TOKEN=your_token_here
